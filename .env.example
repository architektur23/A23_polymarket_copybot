# ════════════════════════════════════════════════════════════════════════════
#  Polymarket Copy Bot — Environment Configuration
#
#  All Polymarket credentials (private key, wallet address, API keys) are
#  entered on the Settings page at http://localhost:2301/settings
#  You do not need to set anything here for the bot to work.
#
#  Only override these if you need non-default infrastructure settings.
#  Copy this file to .env to apply overrides.
# ════════════════════════════════════════════════════════════════════════════

# ── Blockchain RPC ───────────────────────────────────────────────────────────
POLYGON_RPC=https://polygon-rpc.com
CHAIN_ID=137

# ── API Base URLs (defaults are correct — only change for staging/testing) ──
CLOB_HOST=https://clob.polymarket.com
DATA_API_HOST=https://data-api.polymarket.com
GAMMA_API_HOST=https://gamma-api.polymarket.com

# ── Application ──────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///data/bot.db
LOG_DIR=data/logs
LOG_LEVEL=INFO
LOG_BUFFER_LINES=500
